# ─────────────────────────────────────────────────────────────────────────────
# tv-zerodha-bot — environment variables
# Copy this file to .env and fill in real values before running.
# .env is gitignored; never commit real secrets.
#
# List fields (TV_ALLOWED_IPS, NATURAL_GAS_NAMES) must be JSON arrays.
# ─────────────────────────────────────────────────────────────────────────────

# ── General ──────────────────────────────────────────────────────────────────
DRY_RUN=true                          # REQUIRED true on first install; set false only after full validation
TRADING_ENABLED=true                  # master kill switch; false blocks new entries but allows exits
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///data/bot.db    # switch to postgresql+psycopg2://user:pass@host/db for multi-instance

# ── Security ─────────────────────────────────────────────────────────────────
WEBHOOK_SECRET=                       # REQUIRED in production; shared HMAC secret with TradingView alert message
TV_ALLOWED_IPS=["52.89.214.238","34.212.75.30","54.218.53.128","52.32.178.7"]
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=                   # REQUIRED before exposing dashboard to internet

# ── Kite Connect ─────────────────────────────────────────────────────────────
KITE_API_KEY=                         # from developers.kite.trade → My Apps
KITE_API_SECRET=                      # from developers.kite.trade → My Apps
KITE_REDIRECT_URL=                    # e.g. https://yourdomain.com/kite/callback
KITE_ACCESS_TOKEN_FILE=data/access_token.enc
KITE_MAX_TOKEN_AGE_HOURS=20
EXPECTED_EGRESS_IP=                   # static IP registered on developers.kite.trade → IP Whitelist
PYOTP_AUTO_LOGIN=false                # unofficial Zerodha auto-login; keep false unless you accept the risk

# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                   # from @BotFather; bot is no-op if empty
TELEGRAM_CHAT_ID=                     # your personal or group chat ID

# ── Risk ─────────────────────────────────────────────────────────────────────
CAPITAL_PER_TRADE=10000               # ₹ premium budget per option trade
TOTAL_CAPITAL=100000                  # ₹ 1 Lakh total; used for % daily-loss cap
RISK_PER_TRADE_PCT=1.0                # % of TOTAL_CAPITAL; used in UNDERLYING_RISK_BASED sizing mode
MAX_DAILY_LOSS_ABS=2000               # ₹ absolute daily loss hard stop
MAX_DAILY_LOSS_PCT=2.0                # % of TOTAL_CAPITAL; kill switch on whichever limit hits first
MAX_TRADES_PER_DAY=10
MAX_OPEN_POSITIONS=3
CONSECUTIVE_LOSSES_LIMIT=3           # circuit breaker; halts trading until manually reset
RR_RATIO=2.0                          # target distance = RR_RATIO × SL distance
MARKET_PROTECTION_PCT=-1.0            # -1 = kiteconnect default; mandatory on all MARKET/SL-M orders

# ── Product ───────────────────────────────────────────────────────────────────
PRODUCT_TYPE=NRML                     # NRML / MIS / CNC

# ── Options (v2) ─────────────────────────────────────────────────────────────
TARGET_DELTA=0.65
DELTA_TOLERANCE=0.05
OPTION_EXPIRY_RULE=NEAREST_WEEKLY     # NEAREST_WEEKLY or NEAREST_MONTHLY
MIN_DAYS_TO_EXPIRY_INDEX=1
MIN_DAYS_TO_EXPIRY_STOCK=3
SKIP_EXPIRY_DAY_CUTOFF_HOUR=14        # IST; if on expiry day and past 14:30, roll to next expiry
SKIP_EXPIRY_DAY_CUTOFF_MINUTE=30
SL_PREMIUM_PCT=0.30                   # Option A: SL if premium drops 30% from entry
USE_DELTA_TRANSLATED_SL=false         # Option B: translate underlying SL via delta (experimental)
MIN_OPTION_PREMIUM_INDEX=5.0          # ₹ minimum LTP for index options; reject below this
MIN_OPTION_PREMIUM_STOCK=2.0          # ₹ minimum LTP for stock/commodity options
MIN_OI_INDEX=1000
MIN_OI_STOCK=100
MAX_SPREAD_PCT=0.05                   # 5% of LTP; reject if bid-ask wider
SIZING_MODE=PREMIUM_BASED             # PREMIUM_BASED or UNDERLYING_RISK_BASED
RISK_FREE_RATE=0.065                  # India 10-yr G-sec proxy for BS/Black-76 delta computation
NATURAL_GAS_NAMES=["NATURALGAS","NATGASMINI"]  # route to near-month future, not option

# ── Breakeven & Trail ────────────────────────────────────────────────────────
# Applied to OPTION PREMIUM (or future price for NATURALGAS).
# Example: CE entry ₹100, SL_PREMIUM_PCT=30% → SL=₹70, risk=₹30
#   Breakeven: premium hits ₹130 (entry + 1.0×risk) → move GTT SL to entry ₹100
#   Trail start: premium hits ₹145 (entry + 1.5×risk) → trail activates
#   Trailing SL = current_premium − (0.5×risk) = current_premium − ₹15; ratchets up only
# Triggered by TradingView "TRAIL" webhook on bar-close; bot modifies GTT at most once per bar.
BREAKEVEN_RR=1.0
TRAIL_RR=1.5
TRAIL_DISTANCE_RR=0.5

# ── Scheduler (IST, HH:MM) ───────────────────────────────────────────────────
LOGIN_REMINDER_TIME=07:30
INSTRUMENTS_REFRESH_TIME=08:30
NSE_SQUAREOFF_TIME=15:15              # NRML: no auto-squareoff; kept for future MIS support
MCX_SQUAREOFF_TIME=23:20

# ── Symbol / Instruments ─────────────────────────────────────────────────────
INSTRUMENTS_CSV_PATH=data/instruments.csv
ROLLOVER_DAYS_BEFORE_EXPIRY=1
ATR_MULTIPLIER=1.5
NIFTY_FREEZE_QTY=1800                 # exchange single-order qty freeze limit; slice via iceberg above this
BANKNIFTY_FREEZE_QTY=900

# ── Encryption (access token at rest) ────────────────────────────────────────
SECRET_KEY=                           # REQUIRED; random 32+ char string; used to derive Fernet encryption key via PBKDF2
                                      # Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
PBKDF2_ITERATIONS=600000              # OWASP 2023 minimum; tune so derivation takes ~100ms on your hardware

# ── Rate limiting & retry ─────────────────────────────────────────────────────
MAX_OPS=10                            # Kite API orders-per-second cap; above this requires SEBI algo registration
WEBHOOK_RATE_LIMIT_PER_MINUTE=60      # per-IP token bucket capacity; TradingView can burst ~50/min
BACKOFF_MAX_TRIES=5
BACKOFF_INITIAL_WAIT_SECS=1.0
